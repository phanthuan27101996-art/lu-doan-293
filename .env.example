VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Hoặc khóa anon JWT (dự án cũ):
# VITE_SUPABASE_ANON_KEY=

# Service role (JWT dạng sb_secret_...) — CHỈ dùng ngoài browser: Edge Functions, `supabase db`, script Node.
# Không đặt prefix VITE_ (sẽ bị bundle lên client = lộ key).
# SUPABASE_SERVICE_ROLE_KEY=

# Nguồn dữ liệu: mock | supabase. Bỏ trống + đủ URL/khóa ở trên → tự dùng supabase (chức vụ, quân nhân, auth).
# VITE_DATA_SOURCE=supabase

# Chế độ mock: chỉ SĐT demo + mật khẩu này mới đăng nhập được (mặc định 123456).
# VITE_MOCK_AUTH_PASSWORD=123456

# Đăng nhập Supabase: SĐT → email dạng {số}{suffix}. Mặc định @gmail.com (VD: 0961040521@gmail.com).
# VITE_AUTH_PHONE_EMAIL_SUFFIX=@gmail.com
